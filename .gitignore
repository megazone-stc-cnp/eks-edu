# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

env.sh
**/env.sh
**/template/*.yaml
.idea/
02_Default_Environment/result.json
02_Default_Environment/template/eksctl.yamlcl
05_Workload_Access_2/pod-identity-deployment.yaml
05_Workload_Access_2/pod-identity-trust-relationship.json
05_Workload_Access_2/pod-identity-workload-policy.json
06_EKS_Cluster_Addon_Irsa/local_env.sh
06_EKS_Cluster_Addon_Irsa/aws-ebs-csi-driver-trust-policy.json
02_Default_Environment/local_env.sh
08_Computing_1/deployment.yaml
08_Computing_1/local_env.sh
08_Computing_1/result.json
**/tmp/*
